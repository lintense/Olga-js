<?xml version="1.0" encoding="utf-8"?>
<configuration>
    <system.webServer>
        <rewrite>
            <rules>
<rule name="Google-api" stopProcessing="true">
    <match url=".*Google-api(.*)" />
    <action type="Rewrite" url="https://generativelanguage.googleapis.com/{R:1}?key={API_KEYS:Google_KEY}" appendQueryString="true" />
</rule>
<rule name="Google-api-tempkey" stopProcessing="true">
    <match url=".*Google-api-tempkey/(.*)" />
    <action type="Rewrite" url="https://generativelanguage.googleapis.com/{R:1}?" appendQueryString="true" />
</rule>
<rule name="Nvidia_GLM-api" stopProcessing="true">
    <match url=".*Nvidia_GLM-api(.*)" />
    
    <conditions>
        <!-- 1. Extract the key name from the incoming Authorization header (Bearer KeyName) -->
        <add input="{HTTP_Authorization}" pattern="^Bearer\s+(.+)$" />
        
        <!-- 2. Use the captured key name {C:1} to look up the value in the API_KEYS rewrite map -->
        <!--    We wrap it in a pattern to capture the resulting secret value into a new {C:1} -->
        <add input="{API_KEYS:{C:1}}" pattern="(.+)" />
    </conditions>
    
    <serverVariables>
        <!-- 2. {C:1} correspond maintenant à la valeur capturée dans la condition ci-dessus -->
        <set name="HTTP_Authorization" value="Bearer {C:1}" />
    </serverVariables>
    
    <action type="Rewrite" url="https://integrate.api.nvidia.com/v1/chat/completions" appendQueryString="true" />
</rule>

               </rules>
<allowedServerVariables>
    <!-- Supprime l'entrée potentiellement existante pour éviter le doublon -->
    <remove name="HTTP_Authorization" />
    <!-- Ajoute l'entrée proprement pour votre application -->
    <add name="HTTP_Authorization" />
</allowedServerVariables>
        </rewrite>
    </system.webServer>
</configuration>